@model AdminChangePasswordVM

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border overflow-hidden">
                <div class="card-header text-white py-3 px-4" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-key-fill display-4 me-3"></i>
                        <div>
                            <h4 class="fw-bold mb-1">Change User Password</h4>
                            <p class="mb-0 small" style="color: #1DB954;">Admin password reset</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <div>
                            <strong>Admin Action:</strong> You are changing the password for another user. No old password is required.
                        </div>
                    </div>

                    <div class="mb-4 p-3 rounded" style="background-color: #f8f9fa; border-left: 4px solid #17A34A;">
                        <p class="mb-1"><strong>User Email:</strong> @Model.UserEmail</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input asp-for="UserId" type="hidden" />
                        <input asp-for="UserEmail" type="hidden" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control form-control-lg" placeholder="Enter new password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            <small class="text-muted">Minimum 6 characters</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" placeholder="Confirm new password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-accent flex-grow-1">
                                <i class="bi bi-check-circle me-2"></i>Change Password
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


@model RoleManagmentVM
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            @* TODO: Add navigation back to user list *@
            <a asp-action="Index" class="d-inline-flex align-items-center gap-2 text-secondary mb-4 text-decoration-none">
                <i class="bi bi-arrow-left"></i> Back to Users
            </a>

            <div class="card border shadow-sm overflow-hidden">
                <div class="card-header text-white py-4" style="background: linear-gradient(135deg, #065f46 0%, #191414 100%);">
                    <h4 class="mb-1 fw-bold">
                        <i class="bi bi-shield-check me-2"></i>Manage User Role
                    </h4>
                    <p class="mb-0 small opacity-75">Assign roles and permissions for this user</p>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <input asp-for="ApplicationUser.Id" hidden />

                        <!-- User Info Card -->
                        <div class="alert alert-light border mb-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="small text-secondary fw-semibold mb-1">Full Name</label>
                                    <p class="mb-0 fw-semibold">@Model.ApplicationUser.Name</p>
                                </div>
                                <div class="col-md-6">
                                    <label class="small text-secondary fw-semibold mb-1">Email</label>
                                    <p class="mb-0 fw-semibold">@Model.ApplicationUser.Email</p>
                                </div>
                                <div class="col-md-6">
                                    <label class="small text-secondary fw-semibold mb-1">Phone</label>
                                    <p class="mb-0">@Model.ApplicationUser.PhoneNumber</p>
                                </div>
                                <div class="col-md-6">
                                    <label class="small text-secondary fw-semibold mb-1">Current Role</label>
                                    <p class="mb-0">
                                        <span class="badge bg-secondary">@Model.ApplicationUser.Role</span>

                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Role Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-person-badge me-1 text-secondary"></i> Assign New Role
                            </label>
                            <select asp-for="ApplicationUser.Role" asp-items="@Model.RoleList"
                                    class="form-select form-select-lg">
                                <option disabled selected>-- Select Role --</option>
                            </select>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Choose the appropriate role for this user
                            </div>
                        </div>

                        <!-- Role Descriptions -->
                        <div class="card bg-light border-0 mb-4">
                            <div class="card-body p-3">
                                <p class="small fw-semibold mb-2 text-secondary">
                                    <i class="bi bi-question-circle me-1"></i> Role Descriptions:
                                </p>
                                <ul class="small mb-0 text-secondary" style="line-height: 1.8;">
                                    <li><strong>Customer:</strong> Can browse and purchase books</li>
                                    <li><strong>Employee:</strong> Can manage orders and inventory</li>
                                    <li><strong>Admin:</strong> Full system access and user management</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            @* TODO: Add cancel button linking back to user list *@
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-circle me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-1"></i> Update Role
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
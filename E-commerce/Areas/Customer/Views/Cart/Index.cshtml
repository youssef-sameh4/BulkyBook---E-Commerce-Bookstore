@model ShoppingCartVM
@{
    var itemCount = Model.shoppingCartList.Count();
}

<div class="container py-4" style="max-width: 1140px;">
    <form method="post">
        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="text-decoration-none text-secondary small fw-medium d-inline-flex align-items-center gap-1 mb-3">
            <i class="bi bi-arrow-left"></i> Continue Shopping
        </a>

        <div class="row g-4 align-items-start">

            <!-- ============ LEFT: Items ============ -->
            <div class="col-lg-7">
                <div class="card border shadow-sm overflow-hidden">
                    <div class="card-header text-white d-flex align-items-center justify-content-between py-3 px-4" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-bag me-2"></i>Your Items</h5>
                        <span class="badge rounded-pill bg-white bg-opacity-25 text-white">@itemCount</span>
                    </div>

                    @if(itemCount==0)
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-cart-x display-4 text-secondary"></i>
                            <p class="text-secondary mt-3 mb-0">Your cart is empty</p>
                        </div>
                    }
                    else{
                    <div class="cart-items-scroll">
                        @foreach(var item in Model.shoppingCartList)
                            {
                            <div class="d-flex gap-3 px-4 py-3 border-bottom cart-item">
                                <!-- Thumbnail -->
                                <a href="#" class="flex-shrink-0">
                                    <div class="rounded overflow-hidden" style="width: 56px; height: 72px;">
                                        @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" class="w-100 h-100 " />
                                            }
                                            else
                                            {
                                        <img src="https://placehold.co/56x72" class="w-100 h-100" style="object-fit: cover;" alt="Product" />        
                                            }

                                        
                                    </div>
                                </a>

                                <!-- Info -->
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <a href="#" class="fw-semibold text-decoration-none d-block text-truncate" style="font-size: 0.85rem;">
                                            @item.Product.Title
                                    </a>
                                    <p class="text-secondary mb-2" style="font-size: 0.7rem;">by @item.Product.Author &middot; @item.Price.ToString("c") each</p>

                                    <div class="d-flex align-items-center gap-2">
                                        <div class="input-group" style="width: 130px;">
                                                <a asp-action="Minus" asp-route-cartId="@item.Id" class="btn btn-outline-secondary btn-sm px-2"><i class="bi bi-dash"></i></a>
                                            <input type="number"  value="@item.Count" min="1"
                                                   class="form-control form-control-sm text-center fw-bold"
                                                   style="min-width: 52px;"
                                                   onchange="updateCart(@item.Id, this.value)" />
                                                <a asp-action="Plus" asp-route-cartId="@item.Id" class="btn btn-outline-success btn-sm px-2"><i class="bi bi-plus-lg"></i></a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Price + Remove -->
                                <div class="text-end flex-shrink-0 d-flex flex-column justify-content-between align-self-stretch">
                                    <span class="fw-bold" style="font-size: 0.9rem;">@((item.Price * item.Count).ToString("c"))</span>
                                        <a asp-action="Remove" asp-route-cartId="@item.Id" class="text-danger text-decoration-none d-inline-flex align-items-center gap-1" style="font-size: 0.7rem;">
                                        <i class="bi bi-trash3"></i> Remove
                                    </a>
                                </div>
                            </div>
                            }

                       

                    </div>
                    }
                   
                </div>
            </div>

            <!-- ============ RIGHT: Checkout sidebar ============ -->
            <div class="col-lg-5">
                <div class="position-lg-sticky" style="top: 80px;">
                    <div class="card border shadow-sm overflow-hidden">

                        <!-- Shipping -->
                        <div class="px-4 pt-4 pb-3">
                            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-file-person" style="color: #17A34A;"></i> Name and Phone
                            </h6>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    
                                    <input asp-for="@Model.OrderHeader.Name" class="form-control form-control-sm" placeholder="Full Name" />
                                    <span asp-validation-for="OrderHeader.Name" class="text-danger" style="font-size: 0.65rem;"></span>
                                </div>
                                <div class="col-6">
                                    <input asp-for="OrderHeader.PhoneNumber" class="form-control form-control-sm" placeholder="Phone" />
                                    <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger" style="font-size: 0.65rem;"></span>
                                </div>
                            </div>
                            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2 pt-3">
                                <i class="bi bi-geo-alt" style="color: #17A34A;"></i> Shipping Address
                            </h6>
                            <div class="mb-2">
                                <input asp-for="OrderHeader.StreetAddress" class="form-control form-control-sm" placeholder="Street Address" />
                                <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger" style="font-size: 0.65rem;"></span>
                            </div>
                            <div class="row g-2">
                                <div class="col-5">
                                    <input asp-for="OrderHeader.City" class="form-control form-control-sm" placeholder="City" />
                                    <span asp-validation-for="OrderHeader.City" class="text-danger" style="font-size: 0.65rem;"></span>
                                </div>
                                <div class="col-3">
                                    <input asp-for="OrderHeader.State" class="form-control form-control-sm" placeholder="State" />
                                    <span asp-validation-for="OrderHeader.State" class="text-danger" style="font-size: 0.65rem;"></span>
                                </div>
                                <div class="col-4">
                                    <input asp-for="OrderHeader.PostalCode" class="form-control form-control-sm" placeholder="Zip Code" />
                                    <span asp-validation-for="OrderHeader.PostalCode" class="text-danger" style="font-size: 0.65rem;"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-0 mx-4" />

                        <!-- Summary -->
                        <div class="px-4 py-3">
                            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-receipt" style="color: #17A34A;"></i> Order Summary
                            </h6>
                            @foreach (var item in Model.shoppingCartList)
                                {
                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.8rem;">
                                        <span class="text-secondary text-truncate me-2">@item.Product.Title &times; 1</span>
                                    <span class="fw-medium flex-shrink-0">@((item.Price * item.Count).ToString("c"))</span>
                                    </div>
                                }
                                <hr class="my-2" />
                            <div class="d-flex justify-content-between" style="font-size: 0.8rem;">
                                <span class="text-secondary">Shipping</span>
                                <span class="fw-semibold" style="color: #17A34A;">Free</span>
                            </div>
                        </div>

                        <!-- Total bar -->
                        <div class="d-flex justify-content-between align-items-center px-4 py-3 text-white" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
                            <span class="text-uppercase fw-semibold small">Total</span>
                            <span class="fw-bold fs-5">@Model.OrderHeader.OrderTotal.ToString("c")</span>
                        </div>

                        <!-- Place Order -->
                        <div class="p-4">
                            <button type="submit" class="btn btn-accent w-100 fw-semibold py-2 d-flex align-items-center justify-content-center gap-2">
                                <i class="bi bi-lock"></i> Place Order
                            </button>
                            <div class="d-flex justify-content-center gap-3 mt-3 text-secondary" style="font-size: 0.7rem;">
                                <span><i class="bi bi-shield-check me-1"></i>Secure</span>
                                <span><i class="bi bi-truck me-1"></i>Free Shipping</span>
                                <span><i class="bi bi-arrow-counterclockwise me-1"></i>Returns</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts{

    <script>
        function updateCart(cartId, count){
            fetch('/Customer/Cart/UpdateCart',{
                method:'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:'cartId='+cartId + '&count=' + count
            }).then(response=>{
                if(response.ok) window.location.reload();
            });
        }
    </script>

    <partial name="_ValidationScriptsPartial" />
}
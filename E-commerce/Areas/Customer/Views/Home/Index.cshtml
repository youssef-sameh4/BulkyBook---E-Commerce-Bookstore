
@model IEnumerable<Product>

<section class="hero-section position-relative">

    <!-- Background Image -->
    <img src="~/images/hero-books.jpg" class="hero-bg" />

    <!-- Dark Overlay -->
    <div class="hero-overlay"></div>

    <!-- Content -->
    <div class="container hero-content">

        <div class="row h-100 align-items-center">

            <div class="col-lg-7 text-white">

                <span class="badge bg-success px-3 py-2 mb-3">
                    📚 Welcome to BulkyBook
                </span>

                <h1 class="display-2 fw-bold mb-4">
                    Discover Your
                    <span class="text-success">
                        Next Favorite Book
                    </span>
                </h1>

                <p class="lead mb-4 text-light">
                    Browse thousands of books from every category.
                    Discover best sellers, new arrivals and timeless classics.
                </p>

                <div class="d-flex gap-3 flex-wrap">

                    <a href="#catalog"
                       class="btn btn-success btn-lg px-5">
                        Browse Books
                    </a>


                </div>

                <div class="row mt-5">

                    <div class="col-4">
                        <h3 class="fw-bold">@Model.Count()+</h3>
                        <small class="text-light">Books</small>
                    </div>

                    <div class="col-4">
                        <h3 class="fw-bold">25+</h3>
                        <small class="text-light">Categories</small>
                    </div>

                    <div class="col-4">
                        <h3 class="fw-bold">1000+</h3>
                        <small class="text-light">Customers</small>
                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- Books -->
<div class="container py-5" id="catalog">

    <div class="text-center mb-5">

        <h2 class="display-5 fw-bold">
            Featured Collection
        </h2>

        <p class="text-secondary">
            Explore our collection of
            <span class="fw-bold text-success">
                @Model.Count()
            </span>
            books.
        </p>

    </div>

    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var product in Model)
            {
                <div class="col">

                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden book-card">

                        <a asp-action="Details"
                           asp-route-productId="@product.Id"
                           class="text-decoration-none">

                            <div style="aspect-ratio:3/4; overflow:hidden;">

                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl"
                                         class="w-100 h-100"
                                         style="object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex justify-content-center align-items-center bg-light">

                                        <i class="bi bi-book display-2 text-secondary"></i>

                                    </div>
                                }

                            </div>

                        </a>

                        <div class="card-body">

                            <span class="badge bg-success mb-2">
                                @product.Category.Name
                            </span>

                            <h5 class="fw-bold mb-2">

                                @product.Title

                            </h5>

                            <p class="text-secondary small">

                                by @product.Author

                            </p>

                            <div class="d-flex justify-content-between align-items-center mt-3">

                                <div>

                                    <h5 class="text-success fw-bold mb-0">

                                        @product.Price100.ToString("c")

                                    </h5>

                                    @if (product.ListPrice > product.Price100)
                                    {
                                        <small class="text-decoration-line-through text-muted">

                                            @product.ListPrice.ToString("c")

                                        </small>
                                    }

                                </div>

                                <a asp-action="Details"
                                   asp-route-productId="@product.Id"
                                   class="btn btn-success">

                                    View

                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>
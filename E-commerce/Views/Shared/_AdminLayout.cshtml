﻿
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BulkyBookWeb</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.css" />
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />

    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: #f8f9fa;
        }

        .admin-sidebar {
            width: 240px;
            background: #191414;
            border-right: 1px solid rgba(255,255,255,0.1);
        }

        .admin-sidebar-nav .nav-link {
            color: #94a3b8;
            font-size: 0.875rem;
            padding: 0.5rem 0.75rem;
            border-radius: 0.375rem;
            text-decoration: none;
        }

            .admin-sidebar-nav .nav-link:hover {
                color: #fff;
                background: rgba(255,255,255,0.05);
            }

            .admin-sidebar-nav .nav-link.active {
                color: #fff;
                background: #17A34A;
            }

        .admin-sidebar-nav .nav-section {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            color: #64748b;
            padding: 0.5rem 0.75rem;
            margin-top: 0.75rem;
        }
    </style>
</head>

<body>

    <!-- Mobile Top Bar -->
    <div class="d-lg-none sticky-top border-bottom" style="background:#191414;">
        <div class="d-flex justify-content-between align-items-center px-3 py-2">
            <button class="btn btn-link text-white p-0" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                <i class="bi bi-list fs-4"></i>
            </button>

            <span class="text-white fw-semibold">Admin Panel</span>

            <button class="btn btn-link text-white p-0">
                <i class="bi bi-moon-stars"></i>
            </button>
        </div>
    </div>

    <!-- Mobile Sidebar -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarOffcanvas" style="background:#191414;">
        <div class="offcanvas-header border-bottom">
            <h6 class="text-white mb-0">BulkyBook <small class="text-success">Admin</small></h6>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body">
            <partial name="_AdminSidebarNav" />
        </div>
    </div>

    <div class="d-flex">

        <!-- Sidebar -->
        <aside class="admin-sidebar d-none d-lg-flex flex-column" style="height:100vh;">

            <div class="p-3 border-bottom">
                <h6 class="text-white mb-0">
                    BulkyBook <small class="text-success">Admin</small>
                </h6>
            </div>

            <nav class="flex-grow-1 overflow-auto p-3">
                <partial name="_AdminSidebarNav" />
            </nav>

            <!-- USER SECTION FIXED -->
            <div class="px-3 pb-3">

                <div class="d-flex align-items-center gap-2 mb-3">

                    <div class="bg-light rounded-circle d-flex justify-content-center align-items-center"
                         style="width:32px;height:32px;">
                        <i class="bi bi-person-fill text-dark"></i>
                    </div>

                    <span class="text-white fw-semibold small text-truncate" style="max-width:140px;">
                        @(User.Identity?.Name ?? "Guest")
                    </span>

                </div>

                <div class="d-flex gap-2">
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                       class="btn btn-sm btn-outline-light flex-grow-1">
                        <i class="bi bi-shop"></i> Store
                    </a>

                    <form method="post" asp-area="Identity" asp-controller="Account" asp-action="Logout">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>

            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-grow-1">
            <div class="p-4">

                <partial name="_Notification" />

                @RenderBody()

            </div>
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>